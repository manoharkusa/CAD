# Xcelium-Specific Makefile - ExpFifo
# Generated by Verification Structure Generator

#===========================================
# COMMON SIMULATION VARIABLES
#===========================================

# Default test
TEST ?= fifo_base_test

# Default verbosity
VERBOSITY ?= UVM_MEDIUM

# Default seed
SEED ?= 1

# File paths (relative to sim directory)
FILELIST = ../filelist.f
TB_TOP = fifo_tb_top

# Results directory
RESULTS_DIR = ../results/xcelium
LOG_FILE = $(RESULTS_DIR)/xcelium_$(TEST)_$(SEED).log

# Common simulation arguments
COMMON_ARGS = +UVM_TESTNAME=$(TEST) +UVM_VERBOSITY=$(VERBOSITY) +ntb_random_seed=$(SEED)

# Coverage options
COV_DIR = $(RESULTS_DIR)/coverage

# Enable waveforms (0=off, 1=on)
WAVES ?= 0

# Enable coverage (0=off, 1=on)  
COV ?= 0

# Waveform options
WAVE_ARGS = -input shm.tcl

#===========================================
# XCELIUM VARIABLES AND OPTIONS
#===========================================

XCELIUM = xrun
XCELIUM_COMP_OPTS = -sv -uvm -64bit -access +rwc -timescale 1ns/1ps +define+XCELIUM
XCELIUM_COMP_OPTS += -nowarn SPDUSD -nowarn SAWSTP -disable_sem2009
XCELIUM_SIM_OPTS = -R -64bit +UVM_NO_RELNOTES

# Add waveform and coverage flags conditionally
ifeq ($(WAVES),1)
    XCELIUM_COMP_OPTS += -input shm.tcl
    WAVE_DB = waves.shm
endif

ifeq ($(COV),1)
    XCELIUM_COMP_OPTS += -coverage all -covdut $(TB_TOP)
    XCELIUM_SIM_OPTS += -covdir $(COV_DIR)/xcelium_cov
endif

#===========================================
# XCELIUM TARGETS
#===========================================

.PHONY: all compile sim run clean clean_all cov_report help debug gui

# Default target
all: run

# Help target
help:
	@echo "Xcelium Simulation Makefile - ExpFifo"
	@echo "====================================="
	@echo "Available targets:"
	@echo "  help       - Show this help message"
	@echo "  all/run    - Compile and run simulation"
	@echo "  compile    - Compile only"
	@echo "  sim        - Run simulation (requires compilation first)"
	@echo "  clean      - Clean build artifacts"
	@echo "  clean_all  - Clean all including results directory"
	@echo "  cov_report - Generate coverage report"
	@echo "  debug      - Launch SimVision for waveform debug"
	@echo "  gui        - Launch SimVision (same as debug)"
	@echo ""
	@echo "VARIABLES:"
	@echo "  TEST       - Test name (default: $(TEST))"
	@echo "  VERBOSITY  - UVM verbosity (default: $(VERBOSITY))"
	@echo "  SEED       - Random seed (default: $(SEED))"
	@echo "  WAVES      - Enable waveforms: 1|0 (default: 0)"
	@echo "  COV        - Enable coverage: 1|0 (default: 0)"
	@echo ""
	@echo "Available tests:"
	@echo "  fifo_base_test, fifo_basic_test, fifo_fill_test,"
	@echo "  fifo_simultaneous_test, fifo_random_test, fifo_wraparound_test,"
	@echo "  fifo_reset_test, fifo_enable_edge_test, fifo_comprehensive_test"
	@echo ""
	@echo "EXAMPLES:"
	@echo "  make run TEST=fifo_random_test SEED=42"
	@echo "  make run TEST=fifo_comprehensive_test WAVES=1"
	@echo "  make run COV=1 VERBOSITY=UVM_HIGH"
	@echo "  make debug  # After running with WAVES=1"

# Complete flow: compile and run (Xcelium does both in one step)
run: $(RESULTS_DIR) $(if $(findstring 1,$(WAVES)),shm.tcl,)
	@echo "==============================================="
	@echo "Compiling and Running ExpFifo with Xcelium..."
	@echo "Test: $(TEST), Seed: $(SEED)"
	@echo "==============================================="
	@if command -v xrun >/dev/null 2>&1; then \
		cd .. && xrun $(XCELIUM_COMP_OPTS) -f $(FILELIST) \
			$(COMMON_ARGS) \
			$(if $(findstring 1,$(WAVES)),-input xcelium/shm.tcl,) \
			$(if $(findstring 1,$(COV)),-coverage all -covdut $(TB_TOP) -covdir xcelium/$(COV_DIR)/xcelium_cov,) \
			-logfile xcelium/$(LOG_FILE) \
			$(XCELIUM_SIM_OPTS); \
		echo "Simulation completed. Check $(LOG_FILE) for results."; \
	else \
		echo "Error: Xcelium (xrun) not found. Please ensure Xcelium is installed and in your PATH."; \
		exit 1; \
	fi

# Compile target (same as run for Xcelium)
compile: $(RESULTS_DIR)
	@echo "==============================================="
	@echo "Compiling ExpFifo with Xcelium..."
	@echo "==============================================="
	@if command -v xrun >/dev/null 2>&1; then \
		cd .. && xrun $(XCELIUM_COMP_OPTS) -f $(FILELIST) \
			$(if $(findstring 1,$(COV)),-coverage all -covdut $(TB_TOP),) \
			-logfile xcelium/$(RESULTS_DIR)/xcelium_compile.log; \
		echo "Compilation completed. Check $(RESULTS_DIR)/xcelium_compile.log for details."; \
	else \
		echo "Error: Xcelium (xrun) not found. Please ensure Xcelium is installed and in your PATH."; \
		exit 1; \
	fi

# Simulation target (for consistency, but Xcelium typically does compile+sim together)
sim:
	@echo "==============================================="
	@echo "Running Xcelium simulation..." 
	@echo "Test: $(TEST), Seed: $(SEED)"
	@echo "==============================================="
	cd .. && $(XCELIUM) $(XCELIUM_SIM_OPTS) $(COMMON_ARGS) \
		$(if $(findstring 1,$(WAVES)),$(WAVE_ARGS),) \
		$(if $(findstring 1,$(COV)),-coverage all -covdut $(TB_TOP) -covdir xcelium/$(COV_DIR)/xcelium,) \
		-logfile xcelium/$(LOG_FILE) | tee xcelium/$(LOG_FILE)

# Clean target
clean:
	@echo "Cleaning Xcelium build artifacts..."
	@rm -rf *.log xcelium.d *.key .simvision *.shm *.fsdb
	@rm -rf cov_work xcrg xcelium.history
	@rm -rf shm.tcl novas.conf novas.rc
	@echo "Xcelium clean completed."

# Clean all (including results directory)
clean_all: clean
	rm -rf $(RESULTS_DIR)

# Coverage report generation
cov_report:
	@if [ "$(COV)" = "1" ] && [ -d "$(COV_DIR)/xcelium_cov" ]; then \
		echo "Generating Xcelium coverage report..."; \
		if command -v imc >/dev/null 2>&1; then \
			imc -load $(COV_DIR)/xcelium_cov -execcmd "report -html $(COV_DIR)/xcelium_coverage_report"; \
			echo "Coverage report available at: $(COV_DIR)/xcelium_coverage_report/index.html"; \
		else \
			echo "Warning: IMC not found. Cannot generate coverage report."; \
		fi \
	elif [ "$(COV)" != "1" ]; then \
		echo "Coverage not enabled. Use COV=1 to enable coverage collection."; \
	else \
		echo "Coverage database not found. Run simulation with COV=1 first."; \
	fi

# Create shm.tcl file for waveform dumping
shm.tcl:
	@echo "Creating shm.tcl for waveform dumping..."
	@echo "database -open -shm waves -into waves.shm -default" > shm.tcl
	@echo "probe -create -database waves -all -memories -variables -packed 8192 -unpacked 8192" >> shm.tcl
	@echo "run" >> shm.tcl
	@echo "quit" >> shm.tcl

# Setup results directory
$(RESULTS_DIR):
	@mkdir -p $(RESULTS_DIR)

#===========================================
# DEBUG TARGETS
#===========================================

# Debug target - launch SimVision with waveforms
debug:
	@if command -v simvision >/dev/null 2>&1 && [ -f "waves.shm" ]; then \
		echo "Launching SimVision..."; \
		simvision waves.shm & \
	elif [ ! -f "waves.shm" ]; then \
		echo "Error: Waveform file not found. Run simulation with WAVES=1 first."; \
	else \
		echo "Warning: SimVision not found. Please ensure SimVision is installed and in your PATH."; \
	fi

# GUI target - same as debug for Xcelium
gui: debug
