# Questa-Specific Makefile - ExpFifo
# Generated by Verification Structure Generator

#===========================================
# COMMON SIMULATION VARIABLES
#===========================================

# Default test
TEST ?= fifo_base_test

# Default verbosity
VERBOSITY ?= UVM_MEDIUM

# Default seed
SEED ?= 1

# File paths (relative to sim directory)
FILELIST = ../filelist.f
TB_TOP = fifo_tb_top

# Results directory
RESULTS_DIR = ../results/questa
LOG_FILE = $(RESULTS_DIR)/questa_$(TEST)_$(SEED).log

# Common simulation arguments
COMMON_ARGS = +UVM_TESTNAME=$(TEST) +UVM_VERBOSITY=$(VERBOSITY) +ntb_random_seed=$(SEED)

# Coverage options
COV_DIR = $(RESULTS_DIR)/coverage

# Enable waveforms (0=off, 1=on)
WAVES ?= 0

# Enable coverage (0=off, 1=on)
COV ?= 0

# Waveform options
WAVE_ARGS = +DUMP_VCD

#===========================================
# QUESTA VARIABLES AND OPTIONS
#===========================================

QUESTA_VLOG = vlog
QUESTA_VSIM = vsim

# UVM Home detection - tries environment variable first, then common paths
UVM_HOME ?= $(shell \
	if [ -n "$$QUESTA_UVM_HOME" ]; then \
		echo "$$QUESTA_UVM_HOME"; \
	elif [ -n "$$QUESTASIM_HOME" ]; then \
		echo "$$QUESTASIM_HOME/verilog_src/uvm-1.2"; \
	elif [ -n "$$MTI_HOME" ]; then \
		echo "$$MTI_HOME/verilog_src/uvm-1.2"; \
	elif command -v vsim >/dev/null 2>&1; then \
		vsim_path=$$(which vsim); \
		vsim_dir=$$(dirname $$vsim_path); \
		if [ -d "$$vsim_dir/../share/modeltech/verilog_src/uvm-1.2" ]; then \
			echo "$$vsim_dir/../share/modeltech/verilog_src/uvm-1.2"; \
		elif [ -d "$$vsim_dir/../verilog_src/uvm-1.2" ]; then \
			echo "$$vsim_dir/../verilog_src/uvm-1.2"; \
		else \
			echo ""; \
		fi \
	else \
		echo ""; \
	fi)

QUESTA_COMP_OPTS = -sv -timescale=1ns/1ps -64 $(if $(UVM_HOME),+incdir+$(UVM_HOME)/src,) -L mtiUvm +define+QUESTA
QUESTA_SIM_OPTS = -64 -c -do "run -all; quit -f" +UVM_NO_RELNOTES -L mtiUvm

# Add waveform and coverage flags conditionally
ifeq ($(WAVES),1)
    QUESTA_SIM_OPTS += -wlf waves.wlf
    WAVE_DB = waves.wlf
endif

ifeq ($(COV),1)
    QUESTA_COMP_OPTS += +cover=bcesfx -coveropt 3
    QUESTA_SIM_OPTS += -coverage -coverstore $(COV_DIR)/questa_cov
endif

# Work library
WORK_LIB = work

#===========================================
# QUESTA TARGETS
#===========================================

.PHONY: all compile sim run clean clean_all cov_report help gui debug

# Default target
all: run

# Help target
help:
	@echo "Questa Simulation Makefile - ExpFifo"
	@echo "====================================="
	@echo "Available targets:"
	@echo "  help       - Show this help message"
	@echo "  all/run    - Compile and run simulation"
	@echo "  compile    - Compile only"
	@echo "  sim        - Run simulation (requires compilation first)"
	@echo "  gui        - Run interactive GUI simulation"
	@echo "  debug      - Launch QuestaSim with waveforms"
	@echo "  clean      - Clean build artifacts"
	@echo "  clean_all  - Clean all including results directory"
	@echo "  cov_report - Generate coverage report"
	@echo ""
	@echo "VARIABLES:"
	@echo "  TEST       - Test name (default: $(TEST))"
	@echo "  VERBOSITY  - UVM verbosity (default: $(VERBOSITY))"
	@echo "  SEED       - Random seed (default: $(SEED))"
	@echo "  WAVES      - Enable waveforms: 1|0 (default: 0)"
	@echo "  COV        - Enable coverage: 1|0 (default: 0)"
	@echo ""
	@echo "ENVIRONMENT VARIABLES (for UVM path detection):"
	@echo "  QUESTA_UVM_HOME - Direct path to UVM installation"
	@echo "  QUESTASIM_HOME  - QuestaSim installation directory"
	@echo "  MTI_HOME        - ModelSim/Questa installation directory"
	@echo ""
	@echo "Available tests:"
	@echo "  fifo_base_test, fifo_basic_test, fifo_fill_test,"
	@echo "  fifo_simultaneous_test, fifo_random_test, fifo_wraparound_test,"
	@echo "  fifo_reset_test, fifo_enable_edge_test, fifo_comprehensive_test"
	@echo ""
	@echo "EXAMPLES:"
	@echo "  make run TEST=fifo_random_test SEED=42"
	@echo "  make run TEST=fifo_comprehensive_test WAVES=1"
	@echo "  make run COV=1 VERBOSITY=UVM_HIGH"
	@echo "  make gui WAVES=1  # Interactive simulation"
	@echo "  make debug        # After running with WAVES=1"

# Complete flow: compile and run
run: $(RESULTS_DIR) compile sim

# Compile target  
compile: $(RESULTS_DIR) setup_lib
	@echo "==============================================="
	@echo "Compiling ExpFifo with Questa..."
	@echo "==============================================="
	@if command -v vlog >/dev/null 2>&1; then \
		if [ -z "$(UVM_HOME)" ]; then \
			echo "Error: UVM_HOME not detected. Please set QUESTA_UVM_HOME, QUESTASIM_HOME, or MTI_HOME environment variable."; \
			echo "Or ensure UVM is in a standard location relative to your Questa installation."; \
			exit 1; \
		fi; \
		echo "Using UVM from: $(UVM_HOME)"; \
		vlog $(QUESTA_COMP_OPTS) \
			$(UVM_HOME)/src/uvm_pkg.sv \
			-work $(WORK_LIB) \
			-l $(RESULTS_DIR)/questa_compile.log; \
		cd ../.. && vlog $(QUESTA_COMP_OPTS) -f filelist.f \
			-work sim/questa/$(WORK_LIB) \
			-l sim/$(RESULTS_DIR)/questa_compile.log; \
		echo "Compilation completed. Check $(RESULTS_DIR)/questa_compile.log for details."; \
	else \
		echo "Error: Questa (vlog) not found. Please ensure QuestaSim is installed and in your PATH."; \
		exit 1; \
	fi

# Simulation target
sim:
	@echo "==============================================="
	@echo "Running Questa simulation..."
	@echo "Test: $(TEST), Seed: $(SEED)" 
	@echo "==============================================="
	@if command -v vsim >/dev/null 2>&1; then \
		vsim $(QUESTA_SIM_OPTS) -lib $(WORK_LIB) $(TB_TOP) $(COMMON_ARGS) \
			$(if $(findstring 1,$(WAVES)),-wlf waves.wlf,) \
			$(if $(findstring 1,$(COV)),-coverage -coverstore $(COV_DIR)/questa_cov,) \
			-l $(LOG_FILE); \
		echo "Simulation completed. Check $(LOG_FILE) for results."; \
	else \
		echo "Error: Questa (vsim) not found. Please ensure QuestaSim is installed and in your PATH."; \
		exit 1; \
	fi

# Interactive simulation target
gui: $(RESULTS_DIR) setup_lib
	@echo "==============================================="
	@echo "Running Questa GUI simulation..."
	@echo "Test: $(TEST), Seed: $(SEED)" 
	@echo "==============================================="
	@if command -v vsim >/dev/null 2>&1; then \
		vsim -gui $(TB_TOP) $(COMMON_ARGS) \
			$(if $(findstring 1,$(WAVES)),-wlf waves.wlf,) \
			$(if $(findstring 1,$(COV)),-coverage -coverstore $(COV_DIR)/questa_cov,) \
			-l $(LOG_FILE); \
	else \
		echo "Error: Questa (vsim) not found. Please ensure QuestaSim is installed and in your PATH."; \
		exit 1; \
	fi

# Clean target
clean:
	@echo "Cleaning Questa build artifacts..."
	@rm -rf *.log $(WORK_LIB) transcript *.wlf *.vstf
	@rm -rf modelsim.ini wlft* wlf*
	@rm -rf *.vcd *.fsdb novas.conf novas.rc
	@echo "Questa clean completed."

# Clean all (including results directory)
clean_all: clean
	rm -rf $(RESULTS_DIR)

# Coverage report generation
cov_report:
	@if [ "$(COV)" = "1" ] && [ -d "$(COV_DIR)/questa_cov" ]; then \
		echo "Generating Questa coverage report..."; \
		if command -v vcover >/dev/null 2>&1; then \
			vcover report -html -htmldir $(COV_DIR)/questa_coverage_report $(COV_DIR)/questa_cov; \
			echo "Coverage report available at: $(COV_DIR)/questa_coverage_report/index.html"; \
		else \
			echo "Warning: vcover not found. Cannot generate coverage report."; \
		fi \
	elif [ "$(COV)" != "1" ]; then \
		echo "Coverage not enabled. Use COV=1 to enable coverage collection."; \
	else \
		echo "Coverage database not found. Run simulation with COV=1 first."; \
	fi

# Setup work library
setup_lib:
	@if [ ! -d "$(WORK_LIB)" ]; then \
		echo "Creating work library..."; \
		if command -v vlib >/dev/null 2>&1; then \
			vlib $(WORK_LIB); \
			vmap work $(WORK_LIB); \
		else \
			echo "Error: Questa tools not found. Please ensure QuestaSim is installed and in your PATH."; \
			exit 1; \
		fi \
	fi

# Setup results directory
$(RESULTS_DIR):
	@mkdir -p $(RESULTS_DIR)

#===========================================
# DEBUG TARGETS
#===========================================

# Debug target - launch QuestaSim with waveforms
debug:
	@if command -v vsim >/dev/null 2>&1 && [ -f "waves.wlf" ]; then \
		echo "Launching QuestaSim with waveforms..."; \
		vsim -view waves.wlf & \
	elif [ ! -f "waves.wlf" ]; then \
		echo "Error: Waveform file not found. Run simulation with WAVES=1 first."; \
	else \
		echo "Warning: QuestaSim not found. Please ensure QuestaSim is installed and in your PATH."; \
	fi
