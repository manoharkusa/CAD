	@echo "  questa     - Compile and run with Questa"
	@echo ""
	@echo "  compile    - Compile only (auto-detects simulator)"
	@echo "  simulate   - Run simulation (auto-detects simulator)"
	@echo "  run        - Compile and run (auto-detects simulator)"
