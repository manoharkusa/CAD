	@echo "  vcs_debug     - Launch Verdi (VCS waveform viewer)"
	@echo "  xcelium_debug - Launch SimVision (Xcelium waveform viewer)"
	@echo "  questa_debug  - Launch QuestaSim viewer (Questa waveform viewer)"
