# Main Verification Makefile - ExpFifo
# Generated by Verification Structure Generator
# This Makefile delegates to simulator-specific Makefiles

#===========================================
# SIMULATION VARIABLES
#===========================================

# Default simulator (can be overridden: make SIM=vcs)
SIM ?= vcs

# Default test
TEST ?= fifo_base_test

# Default verbosity
VERBOSITY ?= UVM_MEDIUM

# Default seed
SEED ?= 1

# Common variables to pass to sub-makefiles
MAKE_VARS = TEST=$(TEST) VERBOSITY=$(VERBOSITY) SEED=$(SEED) WAVES=$(WAVES) COV=$(COV)

#===========================================
# SIMULATOR PATHS
#===========================================

VCS_DIR = vcs
XCELIUM_DIR = xcelium
QUESTA_DIR = questa
REGRESSION_DIR = regression

#===========================================
# DEFAULT AND HELP TARGETS
#===========================================

.PHONY: all help clean clean_all

# Default target
all: help

# Help target
help:
