#===========================================
# SIMULATOR-SPECIFIC TARGETS
#===========================================

.PHONY: vcs xcelium questa vcs_help xcelium_help questa_help

# VCS targets
vcs:
	@echo "Delegating to VCS Makefile..."
	@$(MAKE) -C $(VCS_DIR) run $(MAKE_VARS)

vcs_compile:
	@$(MAKE) -C $(VCS_DIR) compile $(MAKE_VARS)

vcs_sim:
	@$(MAKE) -C $(VCS_DIR) sim $(MAKE_VARS)

vcs_clean:
	@$(MAKE) -C $(VCS_DIR) clean

vcs_clean_all:
	@$(MAKE) -C $(VCS_DIR) clean_all

vcs_cov_report:
	@$(MAKE) -C $(VCS_DIR) cov_report

vcs_debug:
	@$(MAKE) -C $(VCS_DIR) debug

vcs_help:
	@$(MAKE) -C $(VCS_DIR) help

# Xcelium targets
xcelium:
	@echo "Delegating to Xcelium Makefile..."
	@$(MAKE) -C $(XCELIUM_DIR) run $(MAKE_VARS)

xcelium_compile:
	@$(MAKE) -C $(XCELIUM_DIR) compile $(MAKE_VARS)

xcelium_sim:
	@$(MAKE) -C $(XCELIUM_DIR) sim $(MAKE_VARS)

xcelium_clean:
	@$(MAKE) -C $(XCELIUM_DIR) clean

xcelium_clean_all:
	@$(MAKE) -C $(XCELIUM_DIR) clean_all

xcelium_cov_report:
	@$(MAKE) -C $(XCELIUM_DIR) cov_report

xcelium_debug:
	@$(MAKE) -C $(XCELIUM_DIR) debug

xcelium_help:
	@$(MAKE) -C $(XCELIUM_DIR) help

# Questa targets
questa:
	@echo "Delegating to Questa Makefile..."
	@$(MAKE) -C $(QUESTA_DIR) run $(MAKE_VARS)

questa_compile:
	@$(MAKE) -C $(QUESTA_DIR) compile $(MAKE_VARS)

questa_sim:
	@$(MAKE) -C $(QUESTA_DIR) sim $(MAKE_VARS)

questa_gui:
	@$(MAKE) -C $(QUESTA_DIR) gui $(MAKE_VARS)

questa_clean:
	@$(MAKE) -C $(QUESTA_DIR) clean

questa_clean_all:
	@$(MAKE) -C $(QUESTA_DIR) clean_all

questa_cov_report:
	@$(MAKE) -C $(QUESTA_DIR) cov_report

questa_debug:
	@$(MAKE) -C $(QUESTA_DIR) debug

questa_help:
	@$(MAKE) -C $(QUESTA_DIR) help

#===========================================
# GENERIC TARGETS (AUTO-DETECT SIMULATOR)
#===========================================

.PHONY: compile simulate run cov_report debug

# Generic compile target (uses SIM variable)
compile:
	@echo "Compiling with $(SIM)..."
	@$(MAKE) $(SIM)_compile $(MAKE_VARS)

# Generic simulate target (uses SIM variable)
simulate:
	@echo "Running simulation with $(SIM)..."
	@$(MAKE) $(SIM)_sim $(MAKE_VARS)

# Generic run target (compile + simulate)
run:
	@echo "Running complete flow with $(SIM)..."
	@$(MAKE) $(SIM) $(MAKE_VARS)

# Generic coverage report target
cov_report:
	@echo "Generating coverage report with $(SIM)..."
	@$(MAKE) $(SIM)_cov_report

# Generic debug target (launch waveform viewer)
debug:
	@echo "Launching debug viewer for $(SIM)..."
	@$(MAKE) $(SIM)_debug

#===========================================
# UTILITY TARGETS
#===========================================

.PHONY: clean clean_all regression regression_random regression_quick regression_parallel setup_dirs

# Clean all simulators
clean:
	@echo "Cleaning all simulator artifacts..."
	@-$(MAKE) vcs_clean 2>/dev/null || echo "VCS clean completed (or VCS not available)"
	@-$(MAKE) xcelium_clean 2>/dev/null || echo "Xcelium clean completed (or Xcelium not available)"
	@-$(MAKE) questa_clean 2>/dev/null || echo "Questa clean completed (or Questa not available)"
	@echo "Cleaning common artifacts..."
	@rm -rf results

# Clean all (including results directories)
clean_all:
	@echo "Cleaning all artifacts including results..."
	@-$(MAKE) vcs_clean_all 2>/dev/null || echo "VCS clean_all completed (or VCS not available)"
	@-$(MAKE) xcelium_clean_all 2>/dev/null || echo "Xcelium clean_all completed (or Xcelium not available)"  
	@-$(MAKE) questa_clean_all 2>/dev/null || echo "Questa clean_all completed (or Questa not available)"
	@rm -rf results

# Regression target
regression:
	@echo "Running regression tests..."
	@if [ -d "$(REGRESSION_DIR)" ]; then 		if [ ! -f "$(REGRESSION_DIR)/run_regression.py" ]; then 			echo "Error: Regression script not found. Please ensure run_regression.py exists."; 			exit 1; 		fi; 		echo "Starting regression with simulator: $(SIM)"; 		cd $(REGRESSION_DIR) && python3 run_regression.py --simulator $(SIM) $(MAKE_VARS); 	else 		echo "Warning: Regression directory not found. Skipping regression tests."; 	fi

# Regression with random seed
regression_random:
	@echo "Running regression tests with random seed..."
	@if [ -d "$(REGRESSION_DIR)" ]; then 		if [ ! -f "$(REGRESSION_DIR)/run_regression.py" ]; then 			echo "Error: Regression script not found. Please ensure run_regression.py exists."; 			exit 1; 		fi; 		RANDOM_SEED=$$RANDOM; 		echo "Starting regression with simulator: $(SIM) and random seed: $$RANDOM_SEED"; 		cd $(REGRESSION_DIR) && python3 run_regression.py --simulator $(SIM) SEED=$$RANDOM_SEED TEST=$(TEST) VERBOSITY=$(VERBOSITY) WAVES=$(WAVES) COV=$(COV); 	else 		echo "Warning: Regression directory not found. Skipping regression tests."; 	fi

# Quick regression (subset of tests)
regression_quick:
	@echo "Running quick regression tests..."
	@if [ -d "$(REGRESSION_DIR)" ]; then 		if [ ! -f "$(REGRESSION_DIR)/run_regression.py" ]; then 			echo "Error: Regression script not found. Please ensure run_regression.py exists."; 			exit 1; 		fi; 		echo "Starting quick regression with simulator: $(SIM)"; 		cd $(REGRESSION_DIR) && python3 run_regression.py --simulator $(SIM) --quick $(MAKE_VARS); 	else 		echo "Warning: Regression directory not found. Skipping regression tests."; 	fi

# Parallel regression
regression_parallel:
	@echo "Running parallel regression tests..."
	@if [ -d "$(REGRESSION_DIR)" ]; then 		if [ ! -f "$(REGRESSION_DIR)/run_regression.py" ]; then 			echo "Error: Regression script not found. Please ensure run_regression.py exists."; 			exit 1; 		fi; 		echo "Starting parallel regression with simulator: $(SIM)"; 		cd $(REGRESSION_DIR) && python3 run_regression.py --simulator $(SIM) --jobs 4 $(MAKE_VARS); 	else 		echo "Warning: Regression directory not found. Skipping regression tests."; 	fi

# Setup directories for all simulators
setup_dirs:
	@echo "Setting up simulator directories..."
	@mkdir -p $(VCS_DIR) $(XCELIUM_DIR) $(QUESTA_DIR)
	@mkdir -p results/vcs results/xcelium results/questa

#===========================================
# VALIDATION TARGETS
#===========================================

.PHONY: validate_sim

# Validate simulator selection
validate_sim:
	@case "$(SIM)" in 		vcs|xcelium|questa) 			echo "Using simulator: $(SIM)" ;; 		*) 			echo "Error: Invalid simulator '$(SIM)'. Valid options: vcs, xcelium, questa" >&2; 			exit 1 ;; 	esac

# Add validation as a dependency for generic targets
compile: validate_sim
simulate: validate_sim
run: validate_sim
cov_report: validate_sim
debug: validate_sim
