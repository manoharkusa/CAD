# VCS-Specific Makefile - ExpFifo
# Generated by Verification Structure Generator

#===========================================
# COMMON SIMULATION VARIABLES
#===========================================

# Default test
TEST ?= fifo_base_test

# Default verbosity
VERBOSITY ?= UVM_MEDIUM

# Default seed
SEED ?= 1

# File paths
FILELIST = ../filelist.f
EXECUTABLE = simv

# Results directory
RESULTS_DIR = ../results/vcs
LOG_FILE = $(RESULTS_DIR)/vcs_$(TEST)_$(SEED).log

# VCS-specific flags
VCS_FLAGS = -sverilog -ntb_opts uvm-1.2 -debug_access+all -kdb -lca -timescale=1ns/1ps -full64 -LDFLAGS -Wl,--no-as-needed +define+VCS
VCS_SIM_FLAGS = -licqueue -full64 -assert svaext +warn=noTFIDF

# Enable waveforms (0=off, 1=on)
WAVES ?= 0
ifeq ($(WAVES),1)
    VCS_FLAGS += -debug_access+all
    VCS_SIM_FLAGS += +USE_FSDB
endif

# Enable coverage (0=off, 1=on)  
COV ?= 0
ifeq ($(COV),1)
    VCS_FLAGS += -cm line+cond+fsm+branch+tgl
    VCS_SIM_FLAGS += -cm line+cond+fsm+branch+tgl
endif

#===========================================
# FILE AND DIRECTORY PATHS
#===========================================

COMPILE_LOG = $(RESULTS_DIR)/vcs_compile.log

#===========================================
# VCS TARGETS
#===========================================

.PHONY: all help compile sim run clean clean_all cov_report debug

# Default target
all: help

help:
	@echo "VCS Simulator Makefile - ExpFifo"
	@echo "================================"
	@echo "Available targets:"
	@echo "  compile    - Compile testbench"
	@echo "  sim        - Run simulation only"
	@echo "  run        - Compile and run (default flow)"
	@echo "  clean      - Clean VCS artifacts"
	@echo "  clean_all  - Clean all VCS files including results"
	@echo "  cov_report - Generate coverage report"
	@echo "  debug      - Launch Verdi for waveform debug"
	@echo "  help       - Show this help"
	@echo ""
	@echo "Variables:"
	@echo "  TEST       - Test name (default: $(TEST))"
	@echo "  VERBOSITY  - UVM verbosity (default: $(VERBOSITY))"
	@echo "  SEED       - Random seed (default: $(SEED))"
	@echo "  WAVES      - Enable waveforms: 1|0 (default: $(WAVES))"
	@echo "  COV        - Enable coverage: 1|0 (default: $(COV))"
	@echo ""
	@echo "Available tests:"
	@echo "  fifo_base_test, fifo_basic_test, fifo_fill_test,"
	@echo "  fifo_simultaneous_test, fifo_random_test, fifo_wraparound_test,"
	@echo "  fifo_reset_test, fifo_enable_edge_test, fifo_comprehensive_test"
	@echo ""
	@echo "Examples:"
	@echo "  make compile"
	@echo "  make run TEST=fifo_random_test SEED=42"
	@echo "  make run WAVES=1 COV=1"

#===========================================
# BUILD TARGETS
#===========================================

$(RESULTS_DIR):
	@mkdir -p $(RESULTS_DIR)

compile: $(RESULTS_DIR)
	@echo "=============================================="
	@echo "Compiling ExpFifo with VCS..."
	@echo "=============================================="
	@if command -v vcs >/dev/null 2>&1; then \
		cd ../.. && vcs $(VCS_FLAGS) -f filelist.f -l sim/results/vcs/vcs_compile.log -o sim/vcs/simv; \
		echo "Compilation completed. Check $(COMPILE_LOG) for details."; \
	else \
		echo "Error: VCS not found. Please ensure VCS is installed and in your PATH."; \
		exit 1; \
	fi

sim: $(EXECUTABLE)
	@echo "=============================================="
	@echo "Running VCS simulation..."
	@echo "Test: $(TEST), Seed: $(SEED)"
	@echo "=============================================="
	@./$(EXECUTABLE) $(VCS_SIM_FLAGS) +UVM_TESTNAME=$(TEST) +UVM_VERBOSITY=$(VERBOSITY) +ntb_random_seed=$(SEED) -l $(LOG_FILE)
	@echo "Simulation completed. Check $(LOG_FILE) for results."

run: compile sim

#===========================================
# UTILITY TARGETS
#===========================================

clean:
	@echo "Cleaning VCS artifacts..."
	@rm -rf *.log simv* csrc *.vpd *.fsdb *.key DVEfiles
	@rm -rf .vcs* vc_hdrs.h ucli.key
	@rm -rf novas.conf novas.rc verdi_config_file
	@rm -rf novas_dump.log
	@echo "VCS clean completed."

clean_all: clean
	@echo "Cleaning VCS results..."
	@rm -rf $(RESULTS_DIR)
	@echo "VCS clean_all completed."

cov_report:
	@if [ "$(COV)" = "1" ] && [ -d "simv.vdb" ]; then \
		echo "Generating VCS coverage report..."; \
		if command -v urg >/dev/null 2>&1; then \
			urg -dir simv.vdb -report $(RESULTS_DIR)/coverage_report; \
			echo "Coverage report available at: $(RESULTS_DIR)/coverage_report/dashboard.html"; \
		else \
			echo "Warning: URG (urg) not found. Cannot generate coverage report."; \
		fi \
	elif [ "$(COV)" != "1" ]; then \
		echo "Coverage not enabled. Use COV=1 to enable coverage collection."; \
	else \
		echo "Coverage database not found. Run simulation with COV=1 first."; \
	fi

#===========================================
# DEPENDENCIES
#===========================================

$(EXECUTABLE): ../../filelist.f
	@$(MAKE) compile

#===========================================
# DEBUG TARGETS
#===========================================

debug:
	@if command -v verdi >/dev/null 2>&1 && [ -f "novas.fsdb" ]; then \
		echo "Launching Verdi..."; \
		verdi -dbdir ./simv.daidir -ssf novas.fsdb & \
	elif [ ! -f "novas.fsdb" ]; then \
		echo "Error: Waveform file not found. Run simulation with WAVES=1 first."; \
	else \
		echo "Warning: Verdi not found. Please ensure Verdi is installed and in your PATH."; \
	fi
